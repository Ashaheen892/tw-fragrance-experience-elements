{
    "name": "tw-fragrance-experience-elements",
    "version": "1.0.0",
    "description": "Interactive fragrance experience storefront elements for Salla Twilight",
    "type": "module",
    "scripts": {
        "dev": "node scripts/clear-chrome-cache.mjs && node --import ./scripts/ignore-tty-eio.mjs ./node_modules/vite/bin/vite.js",
        "build": "vite build",
        "preview": "node scripts/clear-chrome-cache.mjs && node --import ./scripts/ignore-tty-eio.mjs ./node_modules/vite/bin/vite.js preview",
        "generate:bundle": "python3 scripts/generate_bundle.py",
        "capture:webps": "node scripts/capture-element-screenshots.mjs",
        "cache:clear": "node scripts/clear-chrome-cache.mjs"
    },
    "devDependencies": {
        "@salla.sa/twilight-bundles": "^0.1.0",
        "playwright": "^1.61.1",
        "sharp": "^0.35.3",
        "typescript": "^5.6.3",
        "vite": "^5.0.0"
    },
    "author": "sajispprt@gmail.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/Ashaheen892/tw-fragrance-experience-elements"
    },
    "private": true,
    "dependencies": {
        "lit": "^3.3.2",
        "swiper": "^11.2.10"
    }
}
